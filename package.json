{
  "name": "meta-app",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicativo de Consultoria em Segurança de Alimentos com IA",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=@meta-app/api",
    "dev:web": "turbo dev --filter=@meta-app/web",
    "db:migrate": "turbo db:migrate --filter=@meta-app/api",
    "db:seed": "turbo db:seed --filter=@meta-app/api",
    "postinstall": "patch-package || true",
    "android": "cd apps/mobile && npx expo run:android",
    "ios": "cd apps/mobile && npx expo run:ios"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "patch-package": "^8.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
