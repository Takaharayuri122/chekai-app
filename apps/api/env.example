# Ambiente
NODE_ENV=development
PORT=3001

# Supabase SDK
# Obtenha estas informações em: https://app.supabase.com/project/[seu-projeto]/settings/api
SUPABASE_URL=https://[SEU_PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Banco de Dados - Supabase (para TypeORM, ainda necessário para algumas operações)
# Obtenha a connection string em: https://app.supabase.com/project/[seu-projeto]/settings/database
# Use a "Connection string" na opção "Connection pooling" (recomendado) ou "Direct connection"
# Formato: postgresql://postgres:[SEU_PASSWORD]@[SEU_PROJECT].supabase.co:5432/postgres
# Substitua [SEU_PASSWORD] pela senha do banco e [SEU_PROJECT] pelo ID do seu projeto
DATABASE_URL=postgresql://postgres:[SEU_PASSWORD]@[SEU_PROJECT].supabase.co:5432/postgres

# JWT
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_EXPIRES_IN=30d

# DeepSeek API
DEEPSEEK_API_KEY=sua-api-key-deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (para embeddings)
OPENAI_API_KEY=sua-api-key-openai

# PDF — logo ChekAI para relatórios (PNG recomendado). Opcional; padrão: site chekai.com.br
CHEKAI_LOGO_URL=https://www.chekai.com.br/images/logo-large.png

# PDF — logar duração e RSS em cada geração (baseline / diagnóstico). Produção: false
PDF_GERACAO_METRICAS=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (usada para links em e-mails de convite, etc.)
FRONTEND_URL=http://localhost:3000

# Email Provider - Escolha entre 'smtp', 'sendgrid', 'mailersend', 'resend' ou 'ethereal'
# Em desenvolvimento: use 'ethereal' (sem configuração necessária, e-mails capturados via Ethereal Mail)
# Em produção: APIs HTTP (HTTPS/443) evitam timeout em ambientes que bloqueiam SMTP — ex.: resend, mailersend, sendgrid
EMAIL_PROVIDER=ethereal

# Resend API (https://resend.com) — EMAIL_PROVIDER=resend
# Crie a API key em: https://resend.com/api-keys
# Domínio de envio deve estar verificado no painel Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@seudominio.com
# Opcional; ignorado se RESEND_FROM já estiver no formato "Nome <email@dominio.com>"
RESEND_FROM_NAME=ChekAI

# SendGrid Web API (recomendado para produção)
# Obtenha sua API key em: https://app.sendgrid.com/settings/api_keys
# Gratuito até 100 emails/dia
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SENDGRID_FROM=noreply@chekai.com

# SMTP - Configuração de e-mail (apenas se EMAIL_PROVIDER=smtp)
# Para Gmail: use porta 587 com SMTP_SECURE=false e crie uma "Senha de App" em https://myaccount.google.com/apppasswords
# Para outros provedores: verifique a documentação do seu provedor SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@chekai.com

